{"nodes": [{"id": "specs_specs_saas_restaurantes", "label": "SaaS-Restaurantes", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a71 Strategic Product Vision", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_financial_resilience", "label": "Financial Resilience", "file_type": "rationale", "source_file": "specs/specs.md", "source_location": "\u00a71 Strategic Product Vision", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Decoupling from global payment processors avoids the 'international gateway trap', achieving immediate cash availability and drastically reduced transaction costs via local P2P Mobile Payments (Pago M\u00f3vil Venezuela). Core priority #1 of the system."}, {"id": "specs_specs_multi_tenant_security", "label": "Multi-tenant Security", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a73 Data Architecture & Multi-tenant Security", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_human_in_the_loop", "label": "Human-in-the-Loop (HITL)", "file_type": "rationale", "source_file": "specs/specs.md", "source_location": "\u00a71 Strategic Product Vision, \u00a77 Payment System", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Technology optimizes flow, but human control ensures final capital validation, adapting to local payment rails. Admin manually verifies each Pago M\u00f3vil transfer by checking their bank app before confirming the payment. Critical for the P2P fraud prevention model."}, {"id": "specs_specs_pago_movil", "label": "Pago M\u00f3vil", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a77 Payment System: Pago M\u00f3vil (Venezuela)", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_commission_system", "label": "Commission System", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a78 Commission System", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "$0.10 per confirmed order displayed as 'Mantenimiento de la App' on receipts. Customer pays the commission as part of total, restaurant receives it, superadmin collects from restaurant manually. Real-time transaction counter is the exclusive billing trigger."}, {"id": "specs_specs_supabase_auth", "label": "Supabase Auth", "file_type": "code", "source_file": "specs/specs.md", "source_location": "\u00a76 Authentication & Authorization", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_rls", "label": "Row-Level Security (RLS)", "file_type": "code", "source_file": "specs/specs.md", "source_location": "\u00a73 Data Architecture & Multi-tenant Security", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_supabase_realtime", "label": "Supabase Realtime", "file_type": "code", "source_file": "specs/specs.md", "source_location": "\u00a79 Supabase Realtime Integration", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_order_lifecycle", "label": "Order Lifecycle", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a75 Operational Flow & Hierarchical Userflow", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "PENDING -> PAYMENT_SENT -> CONFIRMED -> PREPARING -> READY -> DELIVERED. CANCELLED can happen from any state. The PAYMENT_SENT state triggers the HITL verification step where admin must manually confirm the P2P payment."}, {"id": "specs_specs_superadmin_role", "label": "SuperAdmin Role", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a74 System Hierarchy & User Perspectives", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_admin_role", "label": "Admin Role", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a74 System Hierarchy & User Perspectives", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_diner_role", "label": "Diner Role", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a74 System Hierarchy & User Perspectives", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_fastapi", "label": "FastAPI", "file_type": "code", "source_file": "specs/specs.md", "source_location": "\u00a72 Mandatory Technology Stack", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_nextjs", "label": "Next.js", "file_type": "code", "source_file": "specs/specs.md", "source_location": "\u00a72 Mandatory Technology Stack", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_postgresql", "label": "PostgreSQL (Supabase)", "file_type": "code", "source_file": "specs/specs.md", "source_location": "\u00a72 Mandatory Technology Stack, \u00a73 Data Architecture", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_data_isolation", "label": "Data Isolation", "file_type": "rationale", "source_file": "specs/specs.md", "source_location": "\u00a73 Data Architecture & Multi-tenant Security", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Data isolation in a multi-tenant environment must be absolute. Security is delegated to the database engine (RLS), not the application layer. Total data isolation is a core architectural principle."}, {"id": "specs_specs_record_immutability", "label": "Record Immutability", "file_type": "rationale", "source_file": "specs/specs.md", "source_location": "\u00a71 Strategic Product Vision, \u00a72 Mandatory Technology Stack", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pydantic strict mode mandatory for schema immutability. Audit trail via order_status_history table logging every status change. Financial sovereignty requires record immutability for trust."}, {"id": "specs_specs_fraud_prevention", "label": "P2P Fraud Prevention", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a77 Payment System: Pago M\u00f3vil (Venezuela)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "UNIQUE(restaurant_id, bank_reference) composite index prevents reusing same bank reference within a restaurant. HITL manual verification by admin provides human oversight. Audit trail via order_status_history for every status change."}, {"id": "specs_specs_mock_data_state", "label": "Mock Data State", "file_type": "concept", "source_file": "specs/specs.md", "source_location": "\u00a710 Frontend Architecture", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_specs_edge_performance", "label": "Edge Performance", "file_type": "rationale", "source_file": "specs/specs.md", "source_location": "\u00a71 Strategic Product Vision, \u00a72 Mandatory Technology Stack", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Dependency hygiene and startup time optimization are critical for serverless and Edge efficiency. Python 3.14+ for optimized cold starts, uv for Rust-based dependency resolution in milliseconds."}], "edges": [{"source": "specs_specs_saas_restaurantes", "target": "specs_specs_fastapi", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/specs.md", "source_location": "\u00a72 Mandatory Technology Stack", "weight": 1.0}, {"source": "specs_specs_saas_restaurantes", "target": "specs_specs_nextjs", "relation": "references", "confidence"